#!/usr/bin/env bash
# Configures ufw to block all incoming traffic except TCP ports 22, 443, and 80

# Install ufw if not already installed
apt-get install -y ufw

# Reset ufw to default (clears existing rules)
ufw --force reset

# Set default policies - deny drops packets (shows as filtered)
ufw default deny incoming
ufw default deny outgoing

# Allow required TCP ports
ufw allow in 22/tcp
ufw allow in 443/tcp
ufw allow in 80/tcp

# Allow outgoing on required ports too
ufw allow out 22/tcp
ufw allow out 443/tcp
ufw allow out 80/tcp
ufw allow out 80/udp
ufw allow out 53
ufw allow out 443

# Enable ufw
ufw --force enable

# Show status
ufw status verbose
