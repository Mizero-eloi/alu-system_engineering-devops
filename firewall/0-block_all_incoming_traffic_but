#!/bin/bash
# setting up firewall
sudo ufw allow 22/tcp
sudo ufw allow 80/tcp
sudo ufw allow 443/tcp
sudo ufw default deny incoming
sudo ufw default allow outgoing
sudo ufw enable

# Change REJECT rules to DROP so ports appear as "filtered" not "closed"
sudo sed -i 's/-j REJECT --reject-with icmp-port-unreachable/-j DROP/g' /etc/ufw/before.rules
sudo sed -i 's/-j REJECT --reject-with tcp-reset/-j DROP/g' /etc/ufw/before.rules
sudo ufw reload
